# omrbench engines. Copy to omrbench.toml and edit.
#
# The config is a list of [[engines]] entries, each one a concrete install of an
# engine. An entry is identified by engine + version (no hand-typed label):
#
#   engine    required  the tool (e.g. "homr"). Shared across versions, so runs
#                       group into one lineage; also the default adapter to load.
#   version   required  this install's version. Together with engine it names the
#                       entry; it also names the run (runs/<engine>-<version>-<ts>/).
#   cmd       required  the shell command to run the engine
#   cwd       optional  working directory; required when cmd must run from a
#                       specific dir (e.g. "poetry run" needs the project dir)
#   adapter   optional  the driver code (class in omrbench/adapters/). Defaults to
#                       `engine`; set only when the driver name differs from the tool
#
# Select with --engine (and --version when an engine has more than one):
#   omrbench run --engine homr --version 0.6.1 --corpus ...

[[engines]]
engine  = "homr"
version = "0.7.0"            # pip/uvx install on PATH
cmd     = "homr"

[[engines]]
engine  = "homr"            # same tool -> same lineage as the entry above
version = "0.6.0"
cmd     = "poetry run homr"
cwd     = "/path/to/homr-v0.6"

[[engines]]
engine  = "audiveris"
version = "5.10.2"
cmd     = "audiveris"
