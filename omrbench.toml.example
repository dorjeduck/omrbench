# omrbench engines. Copy to omrbench.toml and edit.
#
# Each [engines.<name>] entry is one runnable instance. The entry name is a unique
# config key (and the --engine value); a run lands in runs/<engine>-<version>-<ts>/.
#
#   engine    required  the tool (e.g. "homr"). Shared across versions, so runs
#                       group into one lineage; also the default adapter to load.
#   version   optional  the version. Declared here; if omitted, omrbench tries to
#                       auto-detect it (e.g. git describe); if neither yields one,
#                       `run` errors. Crucial — it names and distinguishes the run.
#   cmd       required  the shell command to run the engine
#   cwd       optional  working directory; required when cmd must run from a
#                       specific dir (e.g. "poetry run" needs the project dir)
#   adapter   optional  the driver code (class in omrbench/adapters/). Defaults to
#                       `engine`; set only when the driver name differs from the tool

[engines.homr]            # pip/uvx install on PATH
engine  = "homr"
version = "0.7.0"         # PATH install has no git to describe -> declare it
cmd     = "homr"

[engines.homr-0_6]        # a specific checkout, benchmarked alongside the above
engine  = "homr"          # same tool -> same lineage as the entry above
cmd     = "poetry run homr"
cwd     = "/path/to/homr-v0.6"   # version auto-detected from this checkout

[engines.audiveris]       # the Audiveris launcher script on PATH
engine  = "audiveris"
version = "5.10.2"
cmd     = "audiveris"
